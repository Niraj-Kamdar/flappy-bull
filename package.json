{
  "name": "flappy-bull-workspace",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "build:program": "cargo build-sbf --arch v3 --manifest-path programs/flappy-bull/Cargo.toml",
    "deploy": "bash scripts/deploy-devnet.sh",
    "init": "node scripts/init-program.mjs",
    "test": "anchor test --provider.cluster devnet",
    "dev": "cd app && npm run dev",
    "copy-idl": "cp target/idl/flappy_bull.json app/src/idl/flappy_bull.json"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "mocha": "^10",
    "ts-mocha": "^10",
    "typescript": "^5",
    "@types/mocha": "^10",
    "@types/node": "^20"
  }
}
